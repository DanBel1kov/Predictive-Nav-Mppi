<?xml version="1.0" encoding="UTF-8"?>
<root main_tree_to_execute="DefaultTree" BTCPP_format="4">
  <include path="BTRegularNav.xml" />

  <BehaviorTree ID="DefaultTree">
<Sequence name="Agent13GroupEvent">
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="35" tolerance="0.20"/>
  <StopAndWaitTimerAction agent_id="{id}" wait_duration="2.5"/>
  <LookAtAgent observer_id="{id}" target_id="14"/>
  <IsLookingAtMe agent_id="{id}" time_step="{dt}" target_id="14" distance_threshold="3.0" angle_threshold="0.6" duration="1.0"/>
  <ConversationFormation main_agent_id="13" non_main_agent_ids="14" goal_id="35" conversation_duration="3.0" time_step="{dt}"/>
  <SaySomething agent_id="{id}" message="follow me"/>
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="36" tolerance="0.20"/>
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="39" tolerance="0.20"/>
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="1" tolerance="0.20"/>
</Sequence>
  </BehaviorTree>
</root>
