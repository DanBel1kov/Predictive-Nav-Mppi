<?xml version="1.0" encoding="UTF-8"?>
<root main_tree_to_execute="DefaultTree" BTCPP_format="4">
  <include path="BTRegularNav.xml" />

  <BehaviorTree ID="DefaultTree">
<Sequence name="Agent15RendezvousLeader">
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="38" tolerance="0.20"/>
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="37" tolerance="0.20"/>
  <StopAndWaitTimerAction agent_id="{id}" wait_duration="2.4"/>
  <LookAtAgent observer_id="{id}" target_id="16"/>
  <IsLookingAtMe agent_id="{id}" time_step="{dt}" target_id="16" distance_threshold="2.5" angle_threshold="0.5" duration="1.0"/>
  <ConversationFormation main_agent_id="15" non_main_agent_ids="16" goal_id="37" conversation_duration="3.5" time_step="{dt}"/>
  <SaySomething agent_id="{id}" message="follow me"/>
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="40" tolerance="0.20"/>
  <GoTo agent_id="{id}" time_step="{dt}" goal_id="3" tolerance="0.20"/>
</Sequence>
  </BehaviorTree>
</root>
